<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="88dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/brand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:letterSpacing="0.12"
                android:text="@string/app_name"
                android:textAllCaps="true"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/headline"
                android:textColor="@color/text_primary"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/subhead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/subhead"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/stereogram_frame"
                android:padding="2dp">

                <com.manticore.toneflow.StereogramView
                    android:id="@+id/stereogram"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/stereogram_cd" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/stereogram_hint"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <!-- Now playing panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/surface_panel"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/now_playing"
                    android:textAllCaps="true"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/selectedPreset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/selectedDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="monospace"
                    android:text="@string/status_paused"
                    android:textColor="@color/accent_soft"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/statusDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Mic panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/surface_panel"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_mic"
                    android:textAllCaps="true"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/mic_hint"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/micSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/mic_feedback"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/micGainLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/mic_gain_default"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/micGainBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:progressTint="@color/accent"
                    android:thumbTint="@color/accent_soft" />

                <TextView
                    android:id="@+id/toneMixLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/tone_mix_default"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/toneMixBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:progressTint="@color/accent"
                    android:thumbTint="@color/accent_soft" />

                <TextView
                    android:id="@+id/micStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="monospace"
                    android:text="@string/mic_status_off"
                    android:textColor="@color/accent_soft"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Sculpt panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/surface_panel"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_sculpt"
                    android:textAllCaps="true"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/mode"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/modeButton"
                            style="@style/CycleChip"
                            android:layout_width="match_parent"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="@string/mode"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/perception"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/perceptionButton"
                            style="@style/CycleChip"
                            android:layout_width="match_parent"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="@string/perception"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/filter"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/filterButton"
                            style="@style/CycleChip"
                            android:layout_width="match_parent"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="@string/filter"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/reverb"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/reverbButton"
                            style="@style/CycleChip"
                            android:layout_width="match_parent"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="@string/reverb"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/carrierLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/carrier_default"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/carrierBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/accent"
                    android:thumbTint="@color/accent_soft" />

                <TextView
                    android:id="@+id/beatLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/beat_default"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/beatBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/accent"
                    android:thumbTint="@color/accent_soft" />

                <TextView
                    android:id="@+id/harmonicsLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/harmonics_default"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/harmonicsBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="2"
                    android:progressTint="@color/accent"
                    android:thumbTint="@color/accent_soft" />

                <TextView
                    android:id="@+id/noiseLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/noise_bed_default"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/noiseBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/accent"
                    android:thumbTint="@color/accent_soft" />

                <TextView
                    android:id="@+id/volumeLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/volume_default"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/volumeBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/accent"
                    android:thumbTint="@color/accent_soft" />
            </LinearLayout>

            <!-- Journeys -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/section_journeys"
                android:textAllCaps="true"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/presetList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/disclaimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/disclaimer"
                android:textColor="@color/text_muted"
                android:textSize="10sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky play bar -->
    <LinearLayout
        android:id="@+id/playBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#E00B1114"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/playButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/play"
            android:textColor="@color/on_accent"
            android:textStyle="bold"
            app:backgroundTint="@color/accent"
            app:cornerRadius="12dp"
            app:rippleColor="#80FFFFFF" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
