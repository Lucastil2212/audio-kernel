<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ManticoreToneFlow" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_soft</item>
        <item name="colorOnPrimary">@color/on_accent</item>
        <item name="colorSecondary">@color/accent_soft</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorControlActivated">@color/accent</item>
        <item name="seekBarStyle">@style/Widget.AppCompat.SeekBar</item>
    </style>

    <style name="CycleChip" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_height">56dp</item>
        <item name="android:background">@drawable/btn_cycle</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="backgroundTint">@null</item>
        <item name="rippleColor">#403DB8A0</item>
    </style>
</resources>
